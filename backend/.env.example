# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/kinondoni_housing
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/kinondoni_housing

# --- Security ---
SECRET_KEY=change-this-to-a-strong-random-secret-key-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# --- ML Model ---
MODEL_ARTIFACT_PATH=./app/ml/artifacts/price_model.joblib

# --- Application ---
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
